# hc-yolink plugin configuration
# Copy to config/config.toml and fill in your values.

# ---------------------------------------------------------------------------
# HomeCore broker connection
# ---------------------------------------------------------------------------
[homecore]
broker_host = "127.0.0.1"
broker_port  = 1883
plugin_id    = "plugin.yolink"
# Password must match the entry in homecore's [[mqtt.clients]] section:
#   [[mqtt.clients]]
#   id       = "plugin.yolink"
#   password = "{bcrypt_hash}"
#   allow_pub = ["homecore/devices/yolink_+/#", "homecore/plugins/plugin.yolink/#"]
#   allow_sub = ["homecore/devices/yolink_+/cmd"]
password = "change_me"

# ---------------------------------------------------------------------------
# YoLink settings
# ---------------------------------------------------------------------------
[yolink]
# "local"  → YS1606 Local Hub (recommended — no cloud dependency)
# "cloud"  → YS1603 / YS1605 (cloud MQTT + API)
mode = "local"

# How often to poll all devices for a full state refresh (seconds).
# MQTT push events are the primary delivery mechanism; this is a safety true-up.
poll_interval_secs = 300

# Temperature unit published to HomeCore.
# Devices report their own native unit; this plugin always converts.
# "F" = Fahrenheit (default)
# "C" = Celsius
temperature_unit = "F"

# ---------------------------------------------------------------------------
# Local mode — YS1606 Local Hub only
# ---------------------------------------------------------------------------
[yolink.local]
# LAN IP address (or hostname) of the YS1606 hub
hub_ip = "192.168.1.50"

# Credentials from YoLink App:
#   Account → Local Hub → Local Network → Integrations → Local API
client_id     = "your_local_client_id"
client_secret = "your_local_client_secret"
net_id        = "your_local_net_id"

# Hub HTTP API port (default 1080)
# api_port = 1080

# Hub MQTT broker port (default 18080)
# mqtt_port = 18080

# ---------------------------------------------------------------------------
# Cloud mode — YS1603 / YS1605
# (only needed when mode = "cloud")
# ---------------------------------------------------------------------------
# [yolink.cloud]
# # User Access Credentials from YoLink App:
# #   Account → Advanced Settings → Personal Access Credentials → [+]
# uaid       = "ua_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# secret_key = "sec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
#
# # Override API and MQTT endpoints for non-US regions
# # api_url   = "https://api.yosmart.com"
# # mqtt_host = "mqtt.api.yosmart.com"
# # mqtt_port = 8003
